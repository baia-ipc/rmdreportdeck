#!/usr/bin/env bash

set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Pack a Rmd into a portable self-contained HTML" > /dev/stderr
  echo "Usage: packhtml <Rmdfile> [param1=value1] [param2=value2] ..." > /dev/stderr
  exit 1
elif [ ! -e "$1" ]; then
  echo "File does not exist: $1" > /dev/stderr
  exit 1
fi

REPORTDECK_COMMAND_PATH="${REPORTDECK_COMMAND_PATH:-$0}" \
  Rscript -e 'rmdreportdeck::packhtml_cli(commandArgs(trailingOnly = TRUE))' "$@"
